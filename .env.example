# ============================================================
# .env.example – copia come .env e compila i valori reali
# ============================================================

# === SERVER ===
PORT=3001
NODE_ENV=development

# === SICUREZZA – CAMBIA OBBLIGATORIAMENTE IN PRODUZIONE ===
# Stringa casuale lunga almeno 32 caratteri
JWT_SECRET=123456789abcdefghilmnopqrstuvwxyz
JWT_EXPIRES_IN=24h

# === ACCOUNT ADMIN INIZIALE ===
# Usati solo al primo avvio per creare l'utente admin nel DB
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Fiori2026!

# === CONTATTI NEGOZIO ===
# Numero WhatsApp in formato internazionale senza + (es: +39 345 1234567 → 393451234567)
WHATSAPP_NUMBER=3331546109

# === DATABASE ===
DB_PATH=./data/fiori-di-sandro.db

# === UPLOAD IMMAGINI ===
UPLOAD_PATH=./uploads
# Dimensione massima file in byte (default 5 MB)
MAX_FILE_SIZE=5242880

# === CORS – URL del frontend ===
FRONTEND_URL=http://localhost:5173

# ============================================================
# PRODUZIONE: file .env nella cartella frontend/
# ============================================================
# VITE_API_URL=https://tuo-backend.onrender.com

# ============================================================
# OPZIONALE: Cloudinary (upload immagini in cloud su produzione)
# ============================================================
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
