# ============================================================
# .env.example - copia come backend/.env e compila i valori reali
# ============================================================

# === SERVER ===
PORT=3001
NODE_ENV=development

# === SICUREZZA - CAMBIA OBBLIGATORIAMENTE IN PRODUZIONE ===
JWT_SECRET=cambia-questo-segreto-in-produzione-minimo-32-caratteri
JWT_EXPIRES_IN=24h

# === ACCOUNT ADMIN INIZIALE ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CambiamiSubito123!

# === SUPABASE (obbligatorio) ===
# Trovi questi valori su: Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://xyzxyzxyz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_STORAGE_BUCKET=products

# === CONTATTI NEGOZIO ===
# Numero WhatsApp in formato internazionale senza + (es: +39 333 154 6109 -> 393331546109)
WHATSAPP_NUMBER=3331546109

# === CORS - URL del frontend ===
FRONTEND_URL=http://localhost:5173

